@inproceedings{zhang2025dynamic,
  selected = {true},
  title = {Dynamic Control of Microgrids with Battery Energy Storage Systems: Grid-Forming and Grid-Following Modes with Adaptive Disconnection Criteria},
  booktitle = {Proc. 9th Int. Conf. on Green Energy and Applications (ICGEA)},
  author = {Xinzhuo Zhang* and Jinjie Liu and Hongjian Sun},
  year = {2025},
  month = mar,
  pages = {1--5},
  publisher = {IEEE},
  address = {Singapore},
  doi = {10.1109/ICGEA64602.2025.11009642},
  abstract = {Reliable operation of hybrid AC microgrids during transitions between grid-connected and islanded modes depends on battery energy storage systems (BESS) that can switch between grid-following (GFL) and grid-forming (GFM) control. This paper proposes adaptive disconnection criteria combining voltage, frequency, and rate-of-change-of-frequency (ROCOF) signals to trigger seamless mode transition. Time-domain simulations in MATLAB/Simulink under IEEE 1547 test scenarios demonstrate stable voltage and frequency recovery within grid-code limits during planned and unplanned islanding events.},
  description = {Adaptive disconnection logic for BESS-supported microgrids that enables seamless switching between grid-following and grid-forming control, validated under IEEE 1547 scenarios.},
  keywords = {Microgrid, Grid-Forming, Grid-Following, BESS, Islanding Detection, Adaptive Control}
}

@article{sarma2025gridforming,
  title = {Grid-Forming Technologies and Regulatory Frameworks: Global Overview for T\"{u}rkiye},
  author = {Nayan Sarma and Kadir Akpinar and Hongjian Sun and Xinzhuo Zhang and Osman Tor},
  year = {2025},
  journal = {Journal of Modern Power Systems and Clean Energy},
  note = {Under review},
  abstract = {This paper reviews grid-forming (GFM) converter technologies and their enabling regulatory frameworks across major power markets, and discusses pathways for adoption in T\"{u}rkiye's evolving converter-dominated grid. The review spans grid codes, ancillary service definitions, procurement mechanisms, and interconnection requirements relevant to GFM inverters.},
  description = {Comparative global review of grid-forming converter technologies and regulatory frameworks, with adoption pathways tailored to T\"{u}rkiye's grid-code evolution.},
  keywords = {Grid-Forming Converters, Grid Code, Regulatory Framework, Power System Regulation}
}

@article{zhang2026adaptive,
  title = {Adaptive Fault Detection and Intelligent Event Classification for Seamless GFL/GFM Transitions in Converter-Dominated Microgrids},
  author = {Xinzhuo Zhang and Hongjian Sun},
  year = {2026},
  journal = {IEEE Transactions on Smart Grid},
  note = {Manuscript in preparation; submission expected Q2 2026},
  abstract = {Converter-dominated microgrids require fault detection and event classification schemes that remain reliable across abrupt changes in effective system inertia as units switch between grid-following and grid-forming control. This manuscript presents an adaptive detection framework combining signal-level event triggering with machine-learning-based classification, validated through MATLAB/Simulink simulation and hardware-in-the-loop testing on IEEE benchmark microgrids.},
  description = {Adaptive event detection and machine-learning-based fault classification tailored to microgrids where converter control mode can change during a disturbance.},
  keywords = {Microgrid, Fault Classification, Event Detection, Machine Learning, Grid-Forming, Grid-Following}
}
